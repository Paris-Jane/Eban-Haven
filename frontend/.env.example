# Copy to `.env.local` for local development (never commit real keys).

# -----------------------------------------------------------------------------
# This app is Vite + React — use VITE_* only.
# NEXT_PUBLIC_* is for Next.js and is NOT read by this project unless you
# rename variables in vite.config (not recommended).
# -----------------------------------------------------------------------------

# Supabase → Project Settings → API
# Project URL (same value you might label NEXT_PUBLIC_SUPABASE_URL elsewhere):
VITE_SUPABASE_URL=https://omuiccjdmakgbebbmfcz.supabase.co

# "anon" / public key — the long JWT starting with eyJ... works with @supabase/supabase-js.
# If Supabase shows a shorter "publishable" key (sb_publishable_...), use whichever the
# dashboard labels as the client-safe key for browser apps; do NOT use the secret key here.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9tdWljY2pkbWFrZ2JlYmJtZmN6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1MTU4MzgsImV4cCI6MjA5MTA5MTgzOH0.VpZUjBkmjOGq1aI060JLwq7aFbgQFgxnFOQNryeuqLk

# Lighthouse data from Supabase (not the .NET API):
# VITE_USE_SUPABASE_DATA=true

# -----------------------------------------------------------------------------
# Keys you must NOT put in Vite env (bundled into the browser):
#   - sb_secret_... / service_role JWT — server & SQL import scripts only
# -----------------------------------------------------------------------------
# For `npm run import:lighthouse` only (terminal env, not .env.local for Vite):
#   SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Optional: deployed ASP.NET API (no trailing slash). Empty = same-origin /api proxy.
# VITE_API_BASE_URL=https://your-api.example.com

# --- On the API host (Azure/Railway/Render), set environment variables, e.g.:
# Supabase__Url=https://YOUR_PROJECT_REF.supabase.co
# Supabase__JwtSecret=<JWT Secret from Supabase Dashboard → Project Settings → API>
# Cors__Origins__0=https://your-app.vercel.app
# Cors__Origins__1=http://localhost:5173
